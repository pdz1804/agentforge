# AgentForge environment (copy to .env; never commit real secrets).

# Model providers (set at least one; choose per-agent via manifest model.provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Web search (Tavily) — used by the web_search tool
TAVILY_API_KEY=

# Postgres (matches infra/docker-compose.yml)
POSTGRES_USER=agentforge
POSTGRES_PASSWORD=agentforge
POSTGRES_DB=agentforge
POSTGRES_PORT=5432
DATABASE_URL=postgresql://agentforge:agentforge@localhost:5432/agentforge

# Added in later phases:
# E2B_API_KEY=            # sandbox (Phase 4)
# MEM0_API_KEY=           # long-term memory (Phase 5)

# Phase 11 hardening (all opt-in — unset means today's open-by-default behavior).
# When set, the API requires this key (via X-API-Key or Authorization: Bearer)
# on sensitive endpoints: POST /api/runs, /api/eval, /api/sandbox/exec,
# /api/index, GET/POST/DELETE /api/memory, and the run-history reads
# (GET /api/runs, /api/runs/{id}, /api/runs/{id}/export).
AGENTFORGE_API_KEY=
# Same key, exposed to the Next.js client so it can send X-API-Key. Unset
# (default) means the web app sends no auth header, matching an unset
# AGENTFORGE_API_KEY on the API.
NEXT_PUBLIC_AGENTFORGE_API_KEY=
# Optional per-endpoint rate-limit overrides (requests/minute); defaults are
# generous and rarely need changing.
# AGENTFORGE_RATE_LIMIT_RUNS_PER_MIN=60
# AGENTFORGE_RATE_LIMIT_EVAL_PER_MIN=30
# AGENTFORGE_RATE_LIMIT_SANDBOX_PER_MIN=30
